{
  "name": "reparacionesfastapi-monolith",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && uvicorn app.socket_app:socket_app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "test:backend": "cd backend && pytest tests -q",
    "test:frontend": "npm --prefix frontend test",
    "lint:frontend": "npm --prefix frontend run lint",
    "build": "npm --prefix frontend ci && npm --prefix frontend run build",
    "start": "cd backend && alembic upgrade head && uvicorn app.socket_app:socket_app --host 0.0.0.0 --port 8000"
  }
}
